//////////////////////
// HUB AVAILABILITY
//////////////////////
model HubOpeningHours {
  id String @id @default(uuid())

  hubId String
  hub   Hub    @relation(fields: [hubId], references: [id], onDelete: Cascade)

  day WeekDay

  openTime  String // "08:00"
  closeTime String // "18:00"

  isClosed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hubId, day])
  @@map("hub_opening_hours")
}

//////////////////////////////////////////////////////
// DELIVERY VERIFICATION
//////////////////////////////////////////////////////

model DeliveryVerification {
  id        String @id @default(uuid())
  bookingId String

  type    String
  fileUrl String?
  otpCode String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

//////////////////////////////////////////////////////
// DELIVERY MODIFICATION
//////////////////////////////////////////////////////

model DeliveryModification {
  id        String @id @default(uuid())
  bookingId String

  newOption     DeliveryOption
  newHubId      String?
  newTripStopId String?

  status String

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

//////////////////////////////////////////////////////
// TRIP STOP (POPUP)
//////////////////////////////////////////////////////

model TripStop {
  id String @id @default(uuid())

  name    String
  country String
  city    String

  // Activation (nullable until activated per trip)
  address   String?
  openDate  DateTime?
  openTime  String?
  closeTime String?

  allowDropoff Boolean @default(true)
  allowPickup  Boolean @default(true)

  order          Int?
  // Ownership (IMPORTANT for security)
  transporteurId String
  transporteur   User   @relation("TransporteurTripStops", fields: [transporteurId], references: [id])

  // Linked trip (optional → reusable template)
  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id])

  dropoffBookings  Booking[] @relation("DropoffTripStop")
  deliveryBookings Booking[] @relation("DeliveryTripStop")

  createdAt DateTime @default(now())

  handoverBatches HandoverBatch[]

  deliveryRouteStops DeliveryRouteStop[] @relation("TripStopDeliveryRouteStops")

  @@index([country, city])
  @@index([tripId, order])
  @@index([transporteurId])
  @@map("trip_stops")
}

model InsurancePlan {
  id String @id @default(uuid())

  name        String
  description String?

  // Pricing logic
  percentageRate Float // e.g. 2.5 (% of declared value)
  minPremium     Float // minimum insurance cost
  maxCoverage    Float // maximum insurable value

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings BookingInsurance[]

  @@map("insurance_plans")
}

model BookingInsurance {
  id String @id @default(uuid())

  bookingId String
  planId    String

  declaredValue  Float
  premiumAmount  Float
  coverageAmount Float

  status InsuranceStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  booking Booking       @relation(fields: [bookingId], references: [id])
  plan    InsurancePlan @relation(fields: [planId], references: [id])

  claims InsuranceClaim[]

  @@unique([bookingId, status]) // ✅ only one ACTIVE insurance
  @@index([bookingId])
  @@index([status])
}

model InsuranceClaim {
  id String @id @default(uuid())

  insuranceId  String
  reason       String
  description  String?
  evidenceUrls Json?

  claimedAmount Float

  status InsuranceClaimStatus @default(SUBMITTED)

  reviewedById String?
  reviewedBy   User?   @relation("ClaimReviewer", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insurance BookingInsurance @relation(fields: [insuranceId], references: [id])

  @@index([insuranceId])
  @@index([status])
  @@map("insurance_claims")
}

model TransporteurRating {
  id String @id @default(uuid())

  bookingId      String @unique
  clientId       String
  transporteurId String

  rating  Int // 1–5
  comment String?

  punctuality   Int?
  communication Int?
  parcelCare    Int?

  createdAt DateTime @default(now())

  booking      Booking @relation(fields: [bookingId], references: [id])
  client       User    @relation("ClientRatings", fields: [clientId], references: [id])
  transporteur User    @relation("TransporteurRatings", fields: [transporteurId], references: [id])

  @@index([transporteurId])
  @@map("transporteur_ratings")
}

model PlatformPricing {
  id String @id @default(uuid())

  // 🌍 Scope
  country String // Trip.departureCountry

  // 💰 Client-facing
  serviceFeeFlat Float

  // 💸 Commission from Transporteur
  commissionRate Float
  vatRate        Float

  // 🏢 Hub fees 
  hubPickupFee   Float? // client drops at hub
  hubDeliveryFee Float? // client picks up at hub
  currency       String @default("EUR")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([country]) // ✅ one config per country
  @@index([country])
}
